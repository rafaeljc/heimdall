{
  "name": "@heimdall/node-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for Heimdall Feature Flags. Provides high-performance, gRPC-based flag evaluation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaeljc/heimdall.git",
    "directory": "sdks/node"
  },
  "author": "Rafael Clemente <43890345+rafaeljc@users.noreply.github.com>",
  "license": "MIT",
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "prebuild": "npm run clean",
    "build": "tsc",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "format:check": "prettier --check 'src/**/*.{ts,js}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@grpc/grpc-js": "^1.10.0",
    "lru-cache": "^11.2.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
